# Local development
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
DATABASE_URL=file:./data/app.db
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-me-on-first-login
BACKUP_DIR=./data/backups
UPLOAD_DIR=./data/uploads
WEB_DIST_DIR=./public

# Local Docker Compose. The container always uses /data paths; these values
# only control the host port, bind mount, and CORS URL for docker-compose.yml.
APP_HOST_PORT=3456
DOCKER_APP_URL=http://localhost:3456
LEDGER_DATA_DIR=./data
