# Public URL used by CORS and cookie-related checks. Change the host.
APP_ENV=production
APP_PORT=3000
APP_URL=http://192.168.1.10:3456

# Keep /data paths unless docker-compose.yml is changed too.
DATABASE_URL=file:/data/app.db
SESSION_SECRET=replace-with-at-least-24-random-characters
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-me-on-first-login
BACKUP_DIR=/data/backups
UPLOAD_DIR=/data/uploads
WEB_DIST_DIR=/app/public
